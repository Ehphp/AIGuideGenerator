# --- Database ---
# Inside the compose network the host is `postgres`.
DATABASE_URL=postgresql+asyncpg://guide:guide@postgres:5432/guide

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed origins for CORS.
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Storage ---
# Absolute path INSIDE the api/worker container. The host directory ./data/storage is mounted here.
STORAGE_DIR=/data/storage

# --- Limits ---
MAX_RECORDING_MB=500
MAX_FRAMES=40

# --- AI (used from Phase 3 onward) ---
OPENAI_API_KEY=
# Leave empty for Whisper auto-detect. Set to e.g. "it" for Italian, "en" for English.
TRANSCRIBE_LANGUAGE=
OPENAI_STT_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o
OPENAI_LLM_MODEL=gpt-4o

# --- Web ---
# URL the browser uses to reach the API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# --- Sanitizer (Phase E) ---
# Set to true to enable PII redaction before sending data to the LLM.
SANITIZE_ENABLED=false
# When true, the pipeline will abort if a leak is detected rather than log and continue.
SANITIZE_STRICT_MODE=false
# Minimum length (chars) a password value must have to be redacted. Default: 4.
SANITIZE_PASSWORD_MIN_LENGTH=4

# --- Evidence matching (Phase F) ---
# Maximum distance in seconds for the nearest-frame fallback when no frame falls
# inside the step's [t_start, t_end] range. Default: 3.0.
EVIDENCE_MAX_NEAREST_SEC=3.0